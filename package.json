{
  "name": "jobctl",
  "version": "0.1.0",
  "description": "jobctl — self-hosted job-search hunter & tracker: scrape public job sources, keyword-score against your profile, triage in a minimal UI",
  "type": "module",
  "license": "MIT",
  "author": "Rahul Prabhu",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahuldamodar94/jobctl.git"
  },
  "homepage": "https://github.com/rahuldamodar94/jobctl#readme",
  "bugs": "https://github.com/rahuldamodar94/jobctl/issues",
  "keywords": [
    "job-search",
    "job-hunt",
    "ats",
    "scraper",
    "greenhouse",
    "lever",
    "ashby",
    "self-hosted",
    "local-first",
    "sqlite",
    "applicant-tracking",
    "web3-jobs"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "scrape": "tsx --env-file-if-exists=.env src/scraper/cli.ts",
    "judge": "tsx --env-file-if-exists=.env src/judge/cli.ts",
    "dev": "concurrently -n server,ui \"tsx watch --env-file-if-exists=.env src/server/index.ts\" \"vite --config src/ui/vite.config.ts\"",
    "build": "vite build --config src/ui/vite.config.ts",
    "start": "tsx --env-file-if-exists=.env src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0",
    "express": "^5.2.1",
    "lucide-react": "^1.18.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.0.227",
    "pdfkit": "^0.19.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.19.0",
    "turndown": "^7.2.4",
    "yaml": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.21",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
